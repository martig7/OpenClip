{
  "name": "open-clip",
  "version": "1.0.0-beta.3",
  "description": "Automatic recording manager for OBS Studio — detects games, organizes recordings, and creates clips.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build": "vite build",
    "dist": "vite build && electron-builder --win",
    "release": "vite build && electron-builder --win --publish always",
    "preview": "vite build && electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:api": "vitest run tests/api/",
    "test:unit": "vitest run tests/unit/",
    "test:components": "vitest run tests/components/",
    "test:integration": "vitest run --config vite.integration.config.js"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "jimp": "^1.6.0",
    "jsqr": "^1.4.0",
    "koffi": "^2.15.1",
    "obs-websocket-js": "^5.0.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "concurrently": "^9.1.2",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.475.0",
    "msw": "^2.12.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.3.0",
    "supertest": "^7.2.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.openclip.app",
    "productName": "Open Clip",
    "copyright": "Copyright © 2026",
    "icon": "assets/icon.ico",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/koffi/**"
    ],
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "ffmpeg/ffmpeg.exe"
      },
      {
        "from": "node_modules/ffprobe-static/bin/win32/x64/ffprobe.exe",
        "to": "ffmpeg/ffprobe.exe"
      },
      {
        "from": "resources/defaults",
        "to": "defaults",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/obs_game_recorder.lua",
        "to": "obs_game_recorder.lua"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Open Clip",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "martig7",
      "repo": "OpenClip",
      "releaseType": "draft"
    }
  }
}
