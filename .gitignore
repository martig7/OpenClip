# Runtime files (created by the application)
/runtime/*
!/runtime/.gitkeep

# Build output (frontend)
/static/

# Python cache
/__pycache__/

# User configuration (may contain personal paths)
manager_settings.json
games_config.json
clip_markers.json

# Claude Code
/.claude

# Project documentation (created by Claude)
/CLAUDE.md

# Game icons (user-specific)
/icons/

# Windows artifacts
nul

# Node modules (frontend has its own .gitignore)
/frontend/node_modules/
/electron-app/node_modules/
/electron-app/dist/

/DEPRECATED/

# OBS Studio local install (for integration testing on Windows)
/obs-studio/

# OBS Studio installer (downloaded in CI, never committed)
/OBS-Studio-*-Installer.exe
obs-plugin/tools/cmake

# OBS plugin build directory (CMake/MSBuild artifacts)
obs-plugin/build/

.vscode/
